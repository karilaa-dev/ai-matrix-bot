# Required Matrix server, owner, and encryption settings.
MATRIX_HOMESERVER_URL=https://matrix.example.org
MATRIX_OWNER_ID=@owner:example.org
# Use at least 32 characters and keep the exact same value when moving the bot.
MATRIX_ENCRYPTION_SECRET=

# Choose exactly one Matrix authentication mode.
# Mode 1: an existing access token (the smallest four-value deployment).
MATRIX_ACCESS_TOKEN=
# Mode 2: let the bot log in and cache its generated token/device in /app/data.
# A full MXID is recommended; a localpart is also accepted.
# MATRIX_LOGIN=@ai-bot:example.org
# MATRIX_PASSWORD=

# Optional integrations. The bot starts without them; the related tools are
# unavailable or reduced until they are configured.
# DOCLING_URL=http://192.168.1.10:5001
# OPENROUTER_API_KEY=replace-me
# TAVILY_API_KEY=replace-me

# Optional model and runtime tuning. Defaults are shown for convenience.
# CODEX_MODEL=gpt-5.6-sol
# CODEX_COMPACTION_MODEL=gpt-5.6-luna
# CODEX_IMAGE_MODEL=gpt-image-2
# CODEX_IMAGE_QUALITY=low
# CODEX_SPEED_MODE=fast
# CODEX_VERBOSITY=high
# REASONING_EFFORT=medium
# REASONING_SUMMARY=detailed
# CODEX_TURN_TIMEOUT_MS=900000
# CODEX_IMAGE_TIMEOUT_MS=300000
# OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b
# DOCLING_TIMEOUT_MS=300000
# CONTEXT_WARN_RATIO=0.85
# BASH_TIMEOUT_MS=30000
# BASH_MAX_OUTPUT_CHARS=12000
# RECENT_WINDOW_MESSAGES=20
# MATRIX_GLOBAL_CONCURRENCY=4
# MATRIX_BATCH_WINDOW_MS=750
# MATRIX_MAX_EVENT_BYTES=60000
# LOG_LEVEL=info
