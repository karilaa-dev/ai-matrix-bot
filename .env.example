# Required Matrix identity and authorization settings.
MATRIX_HOMESERVER_URL=https://matrix.example.org
MATRIX_BOT_USER_ID=@ai-bot:example.org
MATRIX_OWNER_ID=@owner:example.org
MATRIX_DEVICE_ID=AI_MATRIX_BOT

# Required: stable bot-device access token. Direct values are the default
# single-container deployment path and take precedence over *_FILE values.
MATRIX_ACCESS_TOKEN=

# Recommended: Matrix recovery key for cross-signing/recovery. Quote it because
# Matrix recovery keys contain spaces.
MATRIX_RECOVERY_KEY=""

# Optional application-level file alternatives for custom secret mounts.
# MATRIX_ACCESS_TOKEN_FILE=secrets/matrix_access_token
# MATRIX_RECOVERY_KEY_FILE=secrets/matrix_recovery_key

# Matrix adapter paths and limits. Compose overrides the paths with persistent
# container locations; the values below are convenient for local development.
MATRIX_STORAGE_PATH=data/matrix/sync.json
MATRIX_CRYPTO_PATH=data/matrix/crypto
MATRIX_DATABASE_PATH=data/matrix-bot.sqlite
# APP_DATABASE_URL=file:data/matrix-bot.sqlite may be used instead.
MATRIX_GLOBAL_CONCURRENCY=4
MATRIX_BATCH_WINDOW_MS=750
MATRIX_MAX_EVENT_BYTES=60000

# Codex core and provider configuration.
CORE_DATABASE_URL=file:data/codex-core.sqlite
FILE_ROOT=data/files
BASH_ROOT=data/bash
CODEX_PATH=codex
CODEX_HOME=
CODEX_WORKING_DIRECTORY=.
CODEX_MODEL=gpt-5.6-sol
CODEX_COMPACTION_MODEL=gpt-5.6-luna
CODEX_IMAGE_MODEL=gpt-image-2
CODEX_IMAGE_QUALITY=low
CODEX_SPEED_MODE=fast
CODEX_VERBOSITY=high
CODEX_TURN_TIMEOUT_MS=900000
CODEX_IMAGE_TIMEOUT_MS=300000
REASONING_EFFORT=medium
REASONING_SUMMARY=detailed
# Required for DOCX conversion and low-text PDF fallback. This must be a
# separately managed Docling server reachable from the bot container, such as
# http://192.168.1.10:5001 or http://docling:5001 on a shared Docker network.
DOCLING_URL=http://192.168.1.10:5001
DOCLING_TIMEOUT_MS=300000
TAVILY_API_KEY=replace-me
OPENROUTER_API_KEY=replace-me
OPENROUTER_EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b
CONTEXT_WARN_RATIO=0.85
BASH_TIMEOUT_MS=30000
BASH_MAX_OUTPUT_CHARS=12000
RECENT_WINDOW_MESSAGES=20

# Minimum logger level: debug, info, warn, or error.
LOG_LEVEL=info
